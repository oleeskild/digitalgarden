THEME=https://raw.githubusercontent.com/kepano/obsidian-minimal/HEAD/theme.css
BASE_THEME=dark
dgHomeLink=true
dgShowBacklinks=false
dgShowLocalGraph=false
dgShowInlineTitle=false
dgShowFileTree=false
dgEnableSearch=false
dgShowToc=false
dgLinkPreview=false
dgShowTags=false
SITE_NAME_HEADER=The Years
SITE_MAIN_LANGUAGE=zh-TW
SITE_BASE_URL=https://theyears.pages.dev/
SHOW_CREATED_TIMESTAMP=true
TIMESTAMP_FORMAT=YYYY-MM-DDTHH:mm
SHOW_UPDATED_TIMESTAMP=true
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=false
NOTE_ICON_INTERNAL_LINKS=false
NOTE_ICON_BACK_LINKS=false
STYLE_SETTINGS_CSS=body.css-settings-manager { --h1-size: 1.5em; --h2-size: 1.25em; --h6-size: 0.8em; --h3-size: 1.125em; --h4-size: 1em; --h5-size: 0.9em; } body.theme-light.css-settings-manager { } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-windows is-frameless is-hidden-frameless obsidian-app is-floating-nav auto-full-screen show-ribbon show-view-header minimal-theme minimal-readable minimal-catppuccin-dark borders-none colorful-headings colorful-active links-ext-on full-width-media minimal-folding chart-default-width table-default-width img-default-width iframe-wide map-default-width css-settings-manager is-maximized callouts-default trim-cols image-blend-dark checkbox-square pdf-seamless-on pdf-invert-dark pdf-blend-dark sidebar-tabs-default tab-names-off vault-profile-default ribbon-hidden maximize-tables-off tabs-default tab-stack-top minimal-tab-title-hover default is-focused
USE_FULL_RESOLUTION_IMAGES=false
dgPassFrontmatter=false